<?xml version="1.0"?>
<!-- File: ~/ros2_ws/src/swerve_robot/swerve_description/urdf/swerve_module.xacro -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="swerve_module" params="prefix x y z">
        
        <!-- Steering Link (Yaw) -->
        <link name="${prefix}_steering_link">
            <visual>
                <geometry>
                    <cylinder radius="0.05" length="0.05"/>
                </geometry>
                <material name="gray">
                    <color rgba="0.5 0.5 0.5 1.0"/>
                </material>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="0.05" length="0.05"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="0.5"/>
                <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0006"/>
            </inertial>
        </link>

        <joint name="${prefix}_steering_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_steering_link"/>
            <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit effort="20.0" velocity="10.0"/>
            <dynamics damping="0.5" friction="0.1"/>
        </joint>

        <!-- Wheel Link (Pitch) -->
        <link name="${prefix}_wheel_link">
            <visual>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <geometry>
                    <cylinder radius="0.1" length="0.05"/>
                </geometry>
                <material name="black">
                    <color rgba="0.1 0.1 0.1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <sphere radius="0.1"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="1.0"/>
                <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
            </inertial>
        </link>

        <joint name="${prefix}_wheel_joint" type="continuous">
            <parent link="${prefix}_steering_link"/>
            <child link="${prefix}_wheel_link"/>
            <origin xyz="0 0 -0.15" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
            <limit effort="20.0" velocity="25.0"/>
            <dynamics damping="0.1" friction="0.05"/>
        </joint>

        <gazebo reference="${prefix}_wheel_link">
            <mu1>1.5</mu1>
            <mu2>1.5</mu2>
            <kp>1000000.0</kp>
            <kd>100.0</kd>
        </gazebo>

    </xacro:macro>

    <!-- Macro for generating the ros2_control interfaces for a module -->
    <xacro:macro name="swerve_ros2_control" params="prefix">
        <joint name="${prefix}_steering_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="${prefix}_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </xacro:macro>

</robot>